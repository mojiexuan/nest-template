# 环境变量配置示例
# 复制此文件为 .env 或 .env.development 并根据需要配置
# 所有配置都是可选的，未配置的功能会自动降级或禁用

# ============ 应用配置 ============
NODE_ENV=development
PORT=13000

# ============ 数据库配置（可选）============
# 未配置时使用 SQLite 内存数据库，适合快速体验
# 配置后使用 PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your-password
# DB_DATABASE=chenille

# ============ Redis配置（可选）============
# 未配置时使用内存存储，适合开发测试
# 配置后使用 Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============ JWT配置（可选）============
# 未配置时使用演示密钥，仅供开发测试
# 生产环境必须配置，且长度至少32位
# JWT_SECRET=your-secret-key-at-least-32-chars-long
# JWT_EXPIRES_IN=7d

# ============ 邮件配置（可选）============
# 未配置时邮件功能不可用
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# ============ CORS配置（可选）============
# 生产环境建议配置允许的域名，多个用逗号分隔
# CORS_ORIGIN=https://example.com,https://www.example.com
