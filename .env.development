# 开发环境配置
# 所有配置都是可选的，未配置的功能会自动降级或禁用

NODE_ENV=development
PORT=13000

# 数据库配置（可选，未配置则使用 SQLite 内存数据库）
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=chenille_dev

# Redis配置（可选，未配置则使用内存存储）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT配置（可选，未配置则认证功能使用演示模式）
# JWT_SECRET=your-development-secret-key-min-16-chars
# JWT_EXPIRES_IN=7d

# 邮件配置（可选）
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
